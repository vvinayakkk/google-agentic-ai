<?xml version="1.0" encoding="utf-8"?>
<!--
    Allows cleartext (HTTP) traffic to:
    - 10.0.2.2  : Android emulator → host localhost (Docker gateway on :8000)
    - 10.0.3.2  : Genymotion emulator → host localhost
    - 192.168.*  : LAN / physical device (change to your PC's IP if needed)
    All other traffic is expected to use HTTPS in production.
-->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <!-- Android emulator → host machine localhost -->
        <domain includeSubdomains="false">10.0.2.2</domain>
        <!-- Genymotion emulator → host machine localhost -->
        <domain includeSubdomains="false">10.0.3.2</domain>
        <!-- Local network (physical device testing) -->
        <domain includeSubdomains="false">192.168.0.101</domain>
        <domain includeSubdomains="false">192.168.1.4</domain>
        <domain includeSubdomains="false">192.168.1.1</domain>
        <domain includeSubdomains="false">192.168.0.1</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
        <domain includeSubdomains="false">localhost</domain>
    </domain-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system"/>
        </trust-anchors>
    </base-config>
</network-security-config>
