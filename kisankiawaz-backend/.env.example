# Copy this to .env and fill in your values
# NEVER commit real secrets — .env is in .gitignore

# ── App ──────────────────────────────────────────────────
APP_NAME=KisanKiAwaaz
ENVIRONMENT=development
DEBUG=true
API_V1_PREFIX=/api/v1
HOST=0.0.0.0
PORT=8000

# ── Security (CHANGE THESE) ─────────────────────────────
JWT_SECRET=<generate-a-64-char-random-string>
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30
INTERNAL_API_KEY=<generate-a-random-api-key>

# ── Database ─────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://<user>:<password>@postgres:5432/<db_name>
DATABASE_URL_SYNC=postgresql://<user>:<password>@postgres:5432/<db_name>
REDIS_URL=redis://redis:6379/0
POSTGRES_USER=<db_user>
POSTGRES_PASSWORD=<db_password>
POSTGRES_DB=<db_name>

# ── External APIs (get your own keys) ───────────────────
OPENWEATHER_API_KEY=<your-openweathermap-api-key>
GEMINI_API_KEY=<your-google-gemini-api-key>
GEMINI_API_KEYS=<comma-separated-gemini-keys>
GROQ_API_KEY=<your-groq-api-key>
GROQ_API_KEYS=<comma-separated-groq-keys>
GROQ_MODEL=llama-3.3-70b-versatile
KEY_BASE_COOLDOWN_SECONDS=20
KEY_MAX_COOLDOWN_SECONDS=300
KEY_ERROR_COOLDOWN_SECONDS=8
KEY_ROUTER_MAX_RETRIES=3
DATA_GOV_API_KEY=<your-data-gov-api-key>
GEMINI_MODEL=gemini-2.0-flash
GCP_PROJECT=<your-gcp-project-id>

# ── Voice / TTS / STT ───────────────────────────────────
GOOGLE_APPLICATION_CREDENTIALS=<path-to-service-account-json>
TTS_PROVIDER=gtts
STT_PROVIDER=google

# ── CORS ─────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:3000"]
