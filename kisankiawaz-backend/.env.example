# Copy this to .env and fill in your values
# NEVER commit real secrets. Keep .env local-only.

# -----------------------------------------------------------------------------
# Runtime / App
# -----------------------------------------------------------------------------
APP_ENV=development
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173,http://127.0.0.1:4173,http://localhost:8000,http://127.0.0.1:8000,http://localhost:19006,http://127.0.0.1:19006,http://localhost:8081,http://127.0.0.1:8081

# -----------------------------------------------------------------------------
# Core Data Stores
# -----------------------------------------------------------------------------
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=farmer

REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

QDRANT_HOST=localhost
QDRANT_PORT=6333

# -----------------------------------------------------------------------------
# Auth / JWT
# -----------------------------------------------------------------------------
# Use a strong random secret (>= 32 chars; recommended 64+ chars)
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_DAYS=7

# -----------------------------------------------------------------------------
# AI / External APIs
# -----------------------------------------------------------------------------
SARVAM_API_KEY=
# Optional legacy weather fallback (main weather intelligence uses Open-Meteo/NASA/SoilGrids)
OPENWEATHERMAP_API_KEY=
# Optional backward-compatible alias used by some legacy tooling
OPENWEATHER_API_KEY=

GEMINI_API_KEY=
GEMINI_API_KEYS=
GROQ_API_KEY=
GROQ_API_KEYS=
GROQ_MODEL=llama-3.3-70b-versatile

KEY_BASE_COOLDOWN_SECONDS=20
KEY_MAX_COOLDOWN_SECONDS=300
KEY_ERROR_COOLDOWN_SECONDS=8
KEY_ROUTER_MAX_RETRIES=3

# data.gov.in market/soil feeds (optional, enables live API fetch)
DATA_GOV_API_KEY=
# data.gov.in mechanization endpoint for equipment insights (optional; falls back to bundled state data)
DATAGOV_API_KEY=your_key_from_data_gov_in
# Optional override for mechanization dataset resource id
DATA_GOV_MECHANIZATION_RESOURCE_ID=
DATAGOV_MECHANIZATION_RESOURCE_ID=

# Weather intelligence cache tuning
WEATHER_FULL_CACHE_TTL_SECONDS=3600
SOIL_COMPOSITION_CACHE_TTL_SECONDS=2592000

# -----------------------------------------------------------------------------
# Service URLs (mostly for local non-compose runs and tests)
# -----------------------------------------------------------------------------
AUTH_SERVICE_URL=http://localhost:8001
FARMER_SERVICE_URL=http://localhost:8002
CROP_SERVICE_URL=http://localhost:8003
MARKET_SERVICE_URL=http://localhost:8004
EQUIPMENT_SERVICE_URL=http://localhost:8005
AGENT_SERVICE_URL=http://localhost:8006
VOICE_SERVICE_URL=http://localhost:8007
NOTIFICATION_SERVICE_URL=http://localhost:8008
SCHEMES_SERVICE_URL=http://localhost:8009
GEO_SERVICE_URL=http://localhost:8010
ADMIN_SERVICE_URL=http://localhost:8011
ANALYTICS_SERVICE_URL=http://localhost:8012

# -----------------------------------------------------------------------------
# Voice pipeline tuning
# -----------------------------------------------------------------------------
SARVAM_STT_URL=https://api.sarvam.ai/speech-to-text
SARVAM_STT_LEGACY_URL=https://api.sarvam.ai/speech-to-text-translate
VOICE_STT_MODEL=saaras:v3
VOICE_STT_MODE=transcribe
VOICE_STT_LEGACY_MODEL=saaras:v2.5
VOICE_STT_TIMEOUT_SECONDS=12
VOICE_STT_LOW_CONFIDENCE_THRESHOLD=0.55
VOICE_TTS_PROVIDER_TIMEOUT_SECONDS=8
VOICE_TTS_TIMEOUT_SECONDS=2
VOICE_AGENT_TIMEOUT_SECONDS=20
VOICE_AGENT_MAX_RETRIES=3
VOICE_AGENT_RETRY_BACKOFF_SECONDS=0.8
VOICE_AGENT_CLIENT_TIMEOUT_SECONDS=35
VOICE_MARKET_TIMEOUT_SECONDS=1.8
VOICE_SERVICE_TIMEOUT_SECONDS=1.6
VOICE_MAX_TTS_CHARS=220

# -----------------------------------------------------------------------------
# Test config
# -----------------------------------------------------------------------------
API_BASE=http://localhost:8000
TEST_PHONE=+919800000001
TEST_PASSWORD=Farmer@123
MAX_CHAT_LATENCY_SECONDS=45
E2E_ADMIN_PHONE=
E2E_ADMIN_PASSWORD=
