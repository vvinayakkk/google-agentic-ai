<body><!--nghm-->
<noscript>
  <style>
    .noscript-fullscreen {
      position: fixed;
      top: 0; left: 0;
      width: 100vw; height: 100vh;
      background: rgba(0, 0, 0, 0.9);
      color: #fff;
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      display: flex;
      align-items: center;
      justify-content: center;
      z-index: 99999;
      padding: 20px;
      box-sizing: border-box;
    }

    .noscript-container {
      background: #fff;
      color: #000;
      max-width: 600px;
      width: 100%;
      border-radius: 12px;
      box-shadow: 0 10px 25px rgba(0,0,0,0.3);
      padding: 30px;
      text-align: center;
      animation: fadeIn 0.5s ease-out;
    }

    .noscript-container img {
      max-width: 300px;
      margin-bottom: 20px;
    }

    .noscript-container h1 {
      font-size: 26px;
      margin-bottom: 15px;
      color: #b00020;
    }

    .noscript-container p {
      font-size: 16px;
      line-height: 1.6;
      color: #333;
    }

    .noscript-container .steps {
      margin-top: 20px;
      background: #f8f9fa;
      padding: 15px;
      border-left: 4px solid #b00020;
      text-align: left;
      font-size: 14px;
    }

    @keyframes fadeIn {
      from { opacity: 0; transform: scale(0.95); }
      to { opacity: 1; transform: scale(1); }
    }
  </style>
  <div class="noscript-fullscreen">
    <div class="noscript-container">
      <img src="assets/images/img/Website/midh_comp.jpg" alt="App Logo">
      <h1>⚠️ JavaScript is Disabled</h1>
      <p>
        This application requires JavaScript to run properly.
        Your browser appears to have JavaScript turned off or does not support it.
      </p>
      <div class="steps">
        <strong>How to enable JavaScript:</strong>
        <ul>
          <li><b>Chrome:</b> Settings → Privacy and Security → Site Settings → JavaScript → Allow</li>
          <li><b>Firefox:</b> Type <code>about:config</code> → search <code>javascript.enabled</code> → set to <code>true</code></li>
          <li><b>Edge:</b> Settings → Cookies and site permissions → JavaScript → Allow</li>
        </ul>
        After enabling JavaScript, <strong>please refresh the page.</strong>
      </div>
    </div>
  </div>
</noscript>


